# Auto-generated config file. Re-generate with ./configure

# ngdevkit-toolkit common tools
M68KAR=/ucrt64/bin/m68k-neogeo-elf-ar
M68KAS=/ucrt64/bin/m68k-neogeo-elf-as
M68KGCC=/ucrt64/bin/m68k-neogeo-elf-gcc
M68KLD=/ucrt64/bin/m68k-neogeo-elf-ld
M68KOBJCOPY=/ucrt64/bin/m68k-neogeo-elf-objcopy
M68KRANLIB=/ucrt64/bin/m68k-neogeo-elf-ranlib
Z80SDAR=/ucrt64/bin/z80-neogeo-ihx-sdar
Z80SDAS=/ucrt64/bin/z80-neogeo-ihx-sdasz80
Z80SDCC=/ucrt64/bin/z80-neogeo-ihx-sdcc
Z80SDLD=/ucrt64/bin/z80-neogeo-ihx-sdldz80
Z80SDOBJCOPY=/ucrt64/bin/z80-neogeo-ihx-sdobjcopy
Z80SDRANLIB=/ucrt64/bin/z80-neogeo-ihx-sdranlib

# ngdevkit location and common flags
TILETOOL=../ngdevkit/tools/tiletool.py

# additional dependencies
CONVERT=/ucrt64/bin/convert
PYTHON=/ucrt64/bin/python3
RSYNC=
GNGEO=/ucrt64/bin/ngdevkit-gngeo

NGLIBDIR=`pkg-config --variable=libdir ngdevkit`

# GnGeo config
GNGEO_GLSL=no
GNGEO_SHADER_PATH=
GLSL_SHADER_PATH=
SHADER_PATH=
SHADER=noop.glslp

# OS-specific
ENABLE_MSYS2=no
ENABLE_MINGW=no
GNGEO_INSTALL_PATH=
